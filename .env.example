# OpenAI (used to write the email narrative; verdict itself is decided deterministically)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4.1-mini

# OpenWeatherMap — free tier, 5-day/3-hour forecast endpoint
OPENWEATHERAPP_API_KEY=...

# Google Cloud — Routes API (computeRoutes) enabled on the project this key belongs to
GOOGLE_MAPS_API_KEY=...

# Resend — transactional email
RESEND_API_KEY=re_...

# LangSmith — tracing for the LLM narrative call. Tracing turns on automatically
# when LANGSMITH_API_KEY is set; leave it blank to disable. LANGSMITH_PROJECT
# names the project runs are grouped under (defaults to "ride-agent" if unset).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
