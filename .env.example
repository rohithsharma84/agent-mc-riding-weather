# OpenAI (used to write the email narrative; verdict itself is decided deterministically)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4.1-mini

# OpenWeatherMap — free tier, 5-day/3-hour forecast endpoint
# (variable name kept as OPENWEATHERAPP_API_KEY to match the key already issued)
OPENWEATHERAPP_API_KEY=...

# Google Cloud — Routes API (computeRoutes) enabled on the project this key belongs to
GOOGLE_MAPS_API_KEY=...

# Resend — transactional email
RESEND_API_KEY=re_...
